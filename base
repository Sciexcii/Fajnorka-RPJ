# ============================================================
def source_Sp(X: torch.Tensor, dim: int) -> torch.Tensor:
    x = X[:, :dim]
    t = X[:, dim:dim+1]
    xc = 0.5 * torch.ones_like(x)
    r2 = torch.sum((x - xc) ** 2, dim=1, keepdim=True)
    pulse = torch.exp(-80.0 * r2) * torch.exp(-60.0 * (t - 0.2) ** 2)
    return 0.5 * pulse


def sample_interior(n: int, dim: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
    return torch.rand(n, dim + 1, device=device, dtype=dtype)


def sample_initial(n: int, dim: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
    X = torch.rand(n, dim + 1, device=device, dtype=dtype)
    X[:, dim] = 0.0
    return X


def sample_boundary(n: int, dim: int, device: torch.device, dtype: torch.dtype) -> Tuple[torch.Tensor, torch.Tensor]:
    per_face = max(1, n // (2 * dim))
    X_list, N_list = [], []

    def rand_xt(m: int) -> torch.Tensor:
        return torch.rand(m, dim + 1, device=device, dtype=dtype)

    count = 0
    for i in range(dim):
        X0 = rand_xt(per_face); X0[:, i] = 0.0
        n0 = torch.zeros(per_face, dim, device=device, dtype=dtype); n0[:, i] = -1.0
        X_list.append(X0); N_list.append(n0); count += per_face

        X1 = rand_xt(per_face); X1[:, i] = 1.0
        n1 = torch.zeros(per_face, dim, device=device, dtype=dtype); n1[:, i] = 1.0
        X_list.append(X1); N_list.append(n1); count += per_face

    rem = n - count
    if rem > 0:
        Xr = rand_xt(rem)
        face_dim = torch.randint(0, dim, (rem,), device=device)
        face_side = torch.randint(0, 2, (rem,), device=device)
        nr = torch.zeros(rem, dim, device=device, dtype=dtype)
        for k in range(rem):
            i = int(face_dim[k].item())
            side = int(face_side[k].item())
            Xr[k, i] = float(side)
            nr[k, i] = -1.0 if side == 0 else 1.0
        X_list.append(Xr); N_list.append(nr)

    Xb = torch.cat(X_list, dim=0)
    nb = torch.cat(N_list, dim=0)
    idx = torch.randperm(Xb.shape[0], device=device)
    return Xb[idx], nb[idx]


def sample_time_slices(n_space: int, times: torch.Tensor, dim: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
    n_times = times.numel()
    X = torch.rand(n_space * n_times, dim + 1, device=device, dtype=dtype)
    for i in range(n_times):
        X[i * n_space:(i + 1) * n_space, dim] = times[i]
    return X


def sample_scenario_batch_interior(mat: MaterialModel, n_scenarios: int, n_total: int, dim: int, device: torch.device, dtype: torch.dtype) -> Tuple[torch.Tensor, torch.Tensor]:
    n_each = max(1, n_total // n_scenarios)
    m_s = mat.sample_material_vector(n_scenarios)
    Xs = []
    ms = []
    for s in range(n_scenarios):
        X = sample_interior(n_each, dim, device, dtype)
        Xs.append(X)
        ms.append(m_s[s:s+1].repeat(n_each, 1))
    return torch.cat(Xs, dim=0), torch.cat(ms, dim=0)


def sample_scenario_batch_boundary(mat: MaterialModel, n_scenarios: int, n_total: int, dim: int, device: torch.device, dtype: torch.dtype) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
    n_each = max(1, n_total // n_scenarios)
    m_s = mat.sample_material_vector(n_scenarios)
    Xs = []
    Ns = []
    ms = []
    for s in range(n_scenarios):
        Xb, nb = sample_boundary(n_each, dim, device, dtype)
        Xs.append(Xb)
        Ns.append(nb)
        ms.append(m_s[s:s+1].repeat(Xb.shape[0], 1))
    return torch.cat(Xs, dim=0), torch.cat(Ns, dim=0), torch.cat(ms, dim=0)


def sample_scenario_batch_initial(mat: MaterialModel, n_scenarios: int, n_total: int, dim: int, device: torch.device, dtype: torch.dtype) -> Tuple[torch.Tensor, torch.Tensor]:
    n_each = max(1, n_total // n_scenarios)
    m_s = mat.sample_material_vector(n_scenarios)
    Xs = []
    ms = []
    for s in range(n_scenarios):
        X0 = sample_initial(n_each, dim, device, dtype)
        Xs.append(X0)
        ms.append(m_s[s:s+1].repeat(X0.shape[0], 1))
    return torch.cat(Xs, dim=0), torch.cat(ms, dim=0)


def sample_scenario_time_slices(mat: MaterialModel, n_scenarios: int, n_space: int, times: torch.Tensor, dim: int, device: torch.device, dtype: torch.dtype) -> Tuple[torch.Tensor, torch.Tensor]:
    m_s = mat.sample_material_vector(n_scenarios)
    Xs = []
    ms = []
    for s in range(n_scenarios):
        Xt = sample_time_slices(n_space, times, dim, device, dtype)
        Xs.append(Xt)
        ms.append(m_s[s:s+1].repeat(Xt.shape[0], 1))
    return torch.cat(Xs, dim=0), torch.cat(ms, dim=0)


# ============================================================
# Setpoints / ambient
# ============================================================
def T_inf(t: torch.Tensor) -> torch.Tensor:
    return 0.2 + 0.05 * torch.sin(2.0 * math.pi * t)


def setpoint_t(t: torch.Tensor, targets: Targets, physics: PhysicsConfig) -> torch.Tensor:
    mode = physics.track_setpoint_mode.lower()
    if mode == "ambient":
        return T_inf(t)
    return torch.full_like(t, float(targets.T_set))


# ============================================================
# Physics residuals
# ============================================================
def compute_q_fourier(T: torch.Tensor, props: Dict[str, torch.Tensor], X: torch.Tensor, dim: int) -> torch.Tensor:
    K = props["K_star"]
    return -K * grad_scalar(T, X, dim)


def phase_equilibrium(T: torch.Tensor, Tm_star: torch.Tensor, physics: PhysicsConfig) -> torch.Tensor:
    return torch.sigmoid(float(physics.phase_beta) * (T - Tm_star))


def loss_phase_consistency(out: Dict[str, torch.Tensor], props: Dict[str, torch.Tensor], X: torch.Tensor, dim: int, physics: PhysicsConfig) -> torch.Tensor:
    mode = physics.phase_mode.lower()
    if mode == "none" or ("phi" not in out):
        return torch.tensor(0.0, device=X.device, dtype=X.dtype)

    phi = out["phi"]
    if mode == "pcm_equilibrium":
        phi_eq = phase_equilibrium(out["T"], props["Tm_star"], physics)
        L_eq = torch.mean((phi - phi_eq) ** 2)
    else:  # "damage"
        L_eq = torch.mean(phi ** 2)

    gphi = grad_scalar(phi, X, dim)
    L_smooth = torch.mean(torch.sum(gphi**2, dim=1, keepdim=True))
    return L_eq + float(physics.phase_smooth_grad_w) * L_smooth


def residual_energy(out: Dict[str, torch.Tensor], props: Dict[str, torch.Tensor], X: torch.Tensor, dim: int, physics: PhysicsConfig) -> torch.Tensor:
    """
    C_hat dT/dt + div(q) + latent - source = 0
    latent is only used for PCM equilibrium mode (enthalpy proxy).
    """
    T = out["T"]
    dTdt = dt_scalar(T, X, dim)
    q = compute_q_fourier(T, props, X, dim)
    divq = div_vector(q, X, dim)

    latent = 0.0
    if physics.phase_mode.lower() == "pcm_equilibrium" and ("phi" in out):
        latent = (1.0 / (props["Ste"] + 1e-12)) * dt_scalar(out["phi"], X, dim)

    rhs = source_Sp(X, dim) if physics.use_sources else torch.zeros_like(dTdt)
    return props["C_hat"] * dTdt + latent + divq - rhs


# ============================================================
# BC / IC
# ============================================================
def residual_bc(out_b: Dict[str, torch.Tensor], props_b: Dict[str, torch.Tensor], Xb: torch.Tensor, nb: torch.Tensor, dim: int, physics: PhysicsConfig, q_ctrl: Optional[torch.Tensor]) -> torch.Tensor:
    T = out_b["T"]
    q = compute_q_fourier(T, props_b, Xb, dim)
    flux_n = -torch.sum(q * nb, dim=1, keepdim=True)

    t = Xb[:, dim:dim+1]
    Tinf = T_inf(t)

    bc = physics.bc_type.lower()
    if bc == "dirichlet":
        return T - Tinf

    if bc == "neumann":
        qN = 0.05 * torch.sin(2 * math.pi * t)
        if q_ctrl is not None:
            qN = qN + q_ctrl
        return flux_n - qN

    Bi_c = props_b["Bi_c"]
    eps = props_b["eps"]
    Bi_r = 0.02 * eps
    q_in = 0.05 * torch.sin(2 * math.pi * t)
    q_total = q_in + (q_ctrl if q_ctrl is not None else 0.0)
    rhs = Bi_c * (T - Tinf) + Bi_r * (T**4 - Tinf**4) + q_total
    return flux_n - rhs


def residual_ic(out0: Dict[str, torch.Tensor], X0: torch.Tensor, physics: PhysicsConfig) -> torch.Tensor:
    T = out0["T"]
    res = [T - torch.full_like(T, 0.2)]
    if physics.phase_mode.lower() != "none" and ("phi" in out0):
        res.append(out0["phi"] - torch.zeros_like(out0["phi"]))
    return torch.cat(res, dim=1)


# ============================================================
# Regularizers / efficiencies
# ============================================================
def entropy_production(out: Dict[str, torch.Tensor], props: Dict[str, torch.Tensor], X: torch.Tensor, dim: int) -> torch.Tensor:
    T = out["T"]
    gT = grad_scalar(T, X, dim)
    K = props["K_star"].clamp(min=1e-12)
    sigma = K * torch.sum(gT**2, dim=1, keepdim=True) / (T.clamp(min=1e-3) ** 2)
    return torch.mean(sigma)


def bounds_penalty(out: Dict[str, torch.Tensor]) -> torch.Tensor:
    T = out["T"]
    pen = torch.mean(torch.relu(T - 1.0) ** 2 + torch.relu(0.0 - T) ** 2)
    if "phi" in out:
        phi = out["phi"]
        pen = pen + torch.mean(torch.relu(phi - 1.0) ** 2 + torch.relu(0.0 - phi) ** 2)
    return pen


def priors_penalty(props: Dict[str, torch.Tensor]) -> torch.Tensor:
    return (
        torch.mean(torch.relu(props["Theta_q"] - 1.0) ** 2)
        + torch.mean(torch.relu(props["Lambda_q"] - 0.2) ** 2)
        + 1e-4 * torch.mean(torch.relu(props["Bi_c"] - 50.0) ** 2)
    )


def eta_rational(x: float, target: float, p: float = 2.0) -> float:
    if target <= 0:
        return 1.0
    r = x / (target + 1e-12)
    return float(1.0 / (1.0 + (r ** p)))


def eta_cap_ratio(x: float, target: float) -> float:
    if target <= 0:
        return 1.0
    return float(min(1.0, x / target))


def eta_gaussian(x: float, mu: float, sigma: float) -> float:
    if sigma <= 0:
        return 1.0 if abs(x - mu) < 1e-12 else 0.0
    z = (x - mu) / sigma
    return float(math.exp(-(z * z)))


def geom_mean(vals: List[float]) -> float:
    prod = 1.0
    for v in vals:
        prod *= max(1e-12, min(1.0, float(v)))
    return float(prod ** (1.0 / len(vals))) if vals else 0.0


# ============================================================
# RAR
# ============================================================
@torch.no_grad()
def _select_rar_indices(residual_abs: torch.Tensor, top_frac: float) -> torch.Tensor:
    r = residual_abs.view(-1)
    k = max(1, int(top_frac * r.numel()))
    _, idx = torch.topk(r, k=k, largest=True, sorted=False)
    return idx


def build_rar_pool(dim: int, pool: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
    return sample_interior(pool, dim, device, dtype)


# ============================================================
# Metrics (grad enabled)
# ============================================================
def evaluate_metrics(
    model: MultiFieldPINN,
    ctrl: Optional[ControlNet],
    mat: MaterialModel,
    physics: PhysicsConfig,
    nd_cfg: NondimConfig,
    targets: Targets,
    n_eval_scenarios: int,
    n_space: int,
    times: torch.Tensor,
    device: torch.device,
    dtype: torch.dtype,
    sps: float,
    mem_gb: float,
) -> Dict[str, float]:
    dim = physics.dim
    model.eval()
    if ctrl is not None:
        ctrl.eval()

    with torch.enable_grad():
        X, mvec = sample_scenario_time_slices(mat, n_eval_scenarios, n_space, times, dim, device, dtype)
        X.requires_grad_(True)
        out = model(X, mvec)
        out = {k: v.float() for k, v in out.items()}
        props = mat.eval(out["T"], out.get("phi", None), mvec, nd_cfg)

        rE = residual_energy(out, props, X, dim, physics)
        E1_rms = float(torch.sqrt(torch.mean(rE**2)).item())

        ent = float(entropy_production(out, props, X, dim).item())

        # reshape: (S, T, N, 1)
        S = n_eval_scenarios
        Tn = times.numel()
        N = n_space
        Tfield = out["T"].view(S, Tn, N, 1)
        T_mean = Tfield.mean(dim=2).squeeze(-1)  # (S,T)
        T_std = Tfield.std(dim=2).squeeze(-1)    # (S,T)

        # setpoint per time
        tcol = times.view(1, Tn).repeat(S, 1)
        sp = setpoint_t(tcol, targets, physics)

        rmse_mean = float(torch.sqrt(torch.mean((T_mean - sp) ** 2)).item())
        tol = float(targets.band_frac * max(abs(targets.T_set), 1e-6))
        frac_in_band = float(((T_mean - sp).abs() <= tol).float().mean().item())

        CV_T = float(torch.mean(T_std / (T_mean.abs() + 1e-12)).item())

        gT = grad_scalar(out["T"], X, dim)
        grad_rms = float(torch.sqrt(torch.mean(torch.sum(gT**2, dim=1))).item())
        diss = float(torch.mean(props["K_star"] * torch.sum(gT**2, dim=1, keepdim=True)).item())

        k_eff_star = float(torch.mean(props["K_star"]).item())
        k_eff_phys = float(k_eff_star * nd_cfg.k_ref)

        phi_mean = 0.0
        latent_ratio = 0.0
        eta_lat = 1.0
        if physics.phase_mode.lower() == "pcm_equilibrium" and ("phi" in out):
            phi = out["phi"]
            phi_mean = float(phi.mean().item())
            dphidt = dt_scalar(phi, X, dim)
            latent_term = (1.0 / (props["Ste"] + 1e-12)) * dphidt
            latent_power = float(torch.mean(torch.abs(latent_term)).item())
            src = source_Sp(X, dim) if physics.use_sources else torch.zeros_like(latent_term)
            src_power = float(torch.mean(torch.abs(src)).item())
            latent_ratio = float(latent_power / (latent_power + src_power + 1e-12))
            eta_lat = eta_gaussian(latent_ratio, targets.latent_ratio_target, targets.latent_ratio_sigma)

        ctrl_rms = 0.0
        if physics.use_control and ctrl is not None and physics.control_boundary:
            Xb, nb, mb = sample_scenario_batch_boundary(mat, n_eval_scenarios, min(4096, n_eval_scenarios * 1024), dim, device, dtype)
            q_ctrl = ctrl.boundary(Xb, nb, mb, physics.control_budget_q).float()
            ctrl_rms = float(torch.sqrt(torch.mean(q_ctrl**2)).item())

        eta_phys = eta_rational(E1_rms, targets.E1rms_target, p=2.0)
        eta_cmp = eta_cap_ratio(sps, targets.sps_target)
        eta_mem = eta_rational(mem_gb, targets.mem_gb_target, p=2.0)
        eta_sim = geom_mean([eta_phys, eta_cmp, eta_mem])

        eta_stab = eta_cap_ratio(frac_in_band, targets.frac_in_band_target)
        eta_trk = eta_rational(rmse_mean, targets.rmse_set_target, p=2.0)
        eta_ctrl = geom_mean([eta_stab, eta_trk, eta_phys, eta_cmp])

        eta_entropy = eta_rational(ent, targets.entropy_target, p=2.0)
        eta_uniform = eta_rational(CV_T, targets.CV_T_target, p=2.0)
        eta_grad = eta_rational(grad_rms, targets.grad_rms_target, p=2.0)
        eta_diss = eta_rational(diss, targets.dissipation_target, p=2.0)

    return {
        "E1_rms": E1_rms,
        "entropy_proxy": ent,
        "rmse_mean": rmse_mean,
        "frac_in_band_mean": frac_in_band,
        "CV_T": CV_T,
        "grad_rms": grad_rms,
        "dissipation": diss,
        "k_eff_phys_est": k_eff_phys,
        "phi_mean": phi_mean,
        "latent_ratio": latent_ratio,
        "ctrl_rms": ctrl_rms,
        "sps": float(sps),
        "mem_gb": float(mem_gb),
        "eta_physics": eta_phys,
        "eta_compute": eta_cmp,
        "eta_memory": eta_mem,
        "eta_sim_core": eta_sim,
        "eta_control_core": eta_ctrl,
        "eta_stability": eta_stab,
        "eta_tracking": eta_trk,
        "eta_entropy": eta_entropy,
        "eta_uniformity": eta_uniform,
        "eta_gradient": eta_grad,
        "eta_dissipation": eta_diss,
        "eta_latent": float(eta_lat),
    }


# ============================================================
# Training
# ============================================================
def train_unified(
    physics: PhysicsConfig,
    nd_cfg: NondimConfig,
    mat_cfg: MaterialConfig,
    net_cfg: NetConfig,
    tr_cfg: TrainConfig,
    targets: Targets,
):
    device = get_device()
    dtype = torch.float32
    configure_torch_for_speed(tr_cfg.seed, deterministic=tr_cfg.deterministic)

    nd = Nondim(nd_cfg)
    mat = MaterialModel(mat_cfg, nd, device, dtype)

    mat_dim = mat_cfg.base_vec_dim + (mat_cfg.micro_vec_dim if mat_cfg.use_microstructure else 0)
    model = MultiFieldPINN(physics.dim, mat_dim, net_cfg, physics, device, dtype).to(device)

    ctrl = None
    if physics.use_control and physics.control_boundary:
        ctrl = ControlNet(physics.dim, mat_dim, hidden=max(64, net_cfg.hidden // 2), depth=max(3, net_cfg.depth // 2)).to(device)

    model = maybe_compile(model, enabled=tr_cfg.compile_model)
    if ctrl is not None:
        ctrl = maybe_compile(ctrl, enabled=tr_cfg.compile_model)

    params = list(model.parameters()) + (list(ctrl.parameters()) if ctrl is not None else [])
    try:
        opt = optim.AdamW(params, lr=tr_cfg.lr, weight_decay=tr_cfg.weight_decay, fused=(device.type == "cuda"))
    except TypeError:
        opt = optim.AdamW(params, lr=tr_cfg.lr, weight_decay=tr_cfg.weight_decay)

    scheduler = None
    if tr_cfg.use_scheduler:
        scheduler = optim.lr_scheduler.ReduceLROnPlateau(
            opt, mode="min", factor=tr_cfg.sched_factor, patience=tr_cfg.sched_patience, min_lr=tr_cfg.sched_min_lr
        )

    amp_enabled = (device.type == "cuda" and tr_cfg.use_amp)
    amp_dtype = torch.bfloat16 if tr_cfg.amp_dtype.lower() == "bf16" else torch.float16
    scaler = make_scaler(device, enabled=amp_enabled)

    log = Logger(tr_cfg.out_dir, tr_cfg.run_name)
    log.log_meta("version", VERSION_TAG)
    log.log_meta("python", platform.python_version())
    log.log_meta("torch", torch.__version__)
    log.log_meta("device", str(device))
    ok, reason = can_use_torch_compile()
    log.log_meta("compile_capability", {"ok": ok, "reason": reason})
    log.log_meta("physics", asdict(physics))
    log.log_meta("nondim", asdict(nd_cfg))
    log.log_meta("material", asdict(mat_cfg))
    log.log_meta("net", asdict(net_cfg))
    log.log_meta("train", asdict(tr_cfg))
    log.log_meta("targets", asdict(targets))

    def pde_ramp(epoch: int) -> float:
        if not tr_cfg.curriculum:
            return 1.0
        return min(1.0, epoch / max(1, tr_cfg.curriculum_epochs))

    stage1_end = max(1, int(tr_cfg.stage1_frac * tr_cfg.epochs))

    def reg_ramp(epoch: int) -> float:
        if epoch <= stage1_end:
            return 0.0
        return min(1.0, (epoch - stage1_end) / max(1, tr_cfg.reg_ramp_epochs))

    rar_pool_X = build_rar_pool(physics.dim, tr_cfg.rar_pool, device, dtype) if tr_cfg.use_rar else None
    rar_top_idx = None

    last_log_time = time.time()
    steps_since_log = 0
    success_streak = 0
    dim = physics.dim

    track_times = torch.tensor(list(tr_cfg.track_times), device=device, dtype=dtype)

    for epoch in range(1, tr_cfg.epochs + 1):
        model.train()
        if ctrl is not None:
            ctrl.train()

        curr_pde = pde_ramp(epoch)
        reg = reg_ramp(epoch)

        # --- scenario-coherent batches ---
        Xi, m_i = sample_scenario_batch_interior(mat, tr_cfg.n_scenarios, tr_cfg.n_interior, dim, device, dtype)
        Xb, nb, m_b = sample_scenario_batch_boundary(mat, tr_cfg.n_scenarios, tr_cfg.n_boundary, dim, device, dtype)
        X0, m_0 = sample_scenario_batch_initial(mat, tr_cfg.n_scenarios, tr_cfg.n_initial, dim, device, dtype)

        Xi.requires_grad_(True)
        Xb.requires_grad_(True)
        X0.requires_grad_(True)

        with autocast_ctx(device, enabled=amp_enabled, dtype=amp_dtype):
            out_i_raw = model(Xi, m_i)
            out_b_raw = model(Xb, m_b)
            out_0_raw = model(X0, m_0)

            q_ctrl_raw = None
            if physics.use_control and ctrl is not None and physics.control_boundary:
                q_ctrl_raw = ctrl.boundary(Xb, nb, m_b, physics.control_budget_q)

        out_i = {k: v.float() for k, v in out_i_raw.items()}
        out_b = {k: v.float() for k, v in out_b_raw.items()}
        out_0 = {k: v.float() for k, v in out_0_raw.items()}
        q_ctrl = q_ctrl_raw.float() if q_ctrl_raw is not None else None

        props_i = mat.eval(out_i["T"], out_i.get("phi", None), m_i, nd_cfg)
        props_b = mat.eval(out_b["T"], out_b.get("phi", None), m_b, nd_cfg)

        # PDE + BC + IC
        rE = residual_energy(out_i, props_i, Xi, dim, physics)
        Lpde = torch.mean(rE**2)

        Lphase = loss_phase_consistency(out_i, props_i, Xi, dim, physics)

        rbc = residual_bc(out_b, props_b, Xb, nb, dim, physics, q_ctrl=q_ctrl)
        Lbc = torch.mean(rbc**2)

        ric = residual_ic(out_0, X0, physics)
        Lic = torch.mean(ric**2)

        # regularizers
        Lent = entropy_production(out_i, props_i, Xi, dim)
        Lbnd = bounds_penalty(out_i)
        Lpri = priors_penalty(props_i)

        # --- time-sliced regulation (aligned with evaluation) ---
        # Build a small tracking batch per scenario (no derivatives needed)
        Xt, mt = sample_scenario_time_slices(mat, tr_cfg.n_scenarios, tr_cfg.n_track_space, track_times, dim, device, dtype)
        with autocast_ctx(device, enabled=amp_enabled, dtype=amp_dtype):
            out_t_raw = model(Xt, mt)
        out_t = {k: v.float() for k, v in out_t_raw.items()}

        S = tr_cfg.n_scenarios
        Tn = track_times.numel()
        N = tr_cfg.n_track_space
        Tfield = out_t["T"].view(S, Tn, N, 1)
        T_mean = Tfield.mean(dim=2).squeeze(-1)  # (S,T)

        tcol = track_times.view(1, Tn).repeat(S, 1)
        sp = setpoint_t(tcol, targets, physics)

        tol = float(targets.band_frac * max(abs(targets.T_set), 1e-6))

        # mean tracking / band
        Ltrack = torch.mean((T_mean - sp) ** 2)
        Lband = torch.mean(torch.relu(torch.abs(T_mean - sp) - tol) ** 2)

        # uniformity (encourage low variance at each time)
        Luni = torch.mean(Tfield.var(dim=2))

        # control penalty
        Lctrl = torch.tensor(0.0, device=device)
        if q_ctrl is not None:
            Lctrl = torch.mean(q_ctrl**2)

        # effective weights (ramped)
        w_track = reg * tr_cfg.w_track
        w_band = reg * tr_cfg.w_band
        w_uni = reg * tr_cfg.w_uniformity

        total = (
            tr_cfg.w_pde * (curr_pde * Lpde)
            + tr_cfg.w_phase * Lphase
            + tr_cfg.w_bc * Lbc
            + tr_cfg.w_ic * Lic
            + tr_cfg.w_entropy * Lent
            + tr_cfg.w_bounds * Lbnd
            + tr_cfg.w_priors * Lpri
            + w_track * Ltrack
            + w_band * Lband
            + w_uni * Luni
            + tr_cfg.w_ctrl * Lctrl
        )

        opt.zero_grad(set_to_none=True)
        scaler.scale(total).backward()

        if tr_cfg.grad_clip and tr_cfg.grad_clip > 0:
            scaler.unscale_(opt)
            nn.utils.clip_grad_norm_(params, tr_cfg.grad_clip)

        scaler.step(opt)
        scaler.update()

        steps_since_log += 1

        # RAR update (single pool)
        if tr_cfg.use_rar and rar_pool_X is not None and (epoch % tr_cfg.rar_every == 0):
            model.eval()
            with torch.enable_grad():
                Xp = rar_pool_X
                mp = mat.sample_material_vector(Xp.shape[0])
                Xp_req = Xp.detach().clone().requires_grad_(True)
                outp = model(Xp_req, mp)
                outp = {k: v.float() for k, v in outp.items()}
                propsp = mat.eval(outp["T"], outp.get("phi", None), mp, nd_cfg)
                rEp = residual_energy(outp, propsp, Xp_req, dim, physics)
                rar_top_idx = _select_rar_indices(torch.abs(rEp).detach(), tr_cfg.rar_top_frac)

        # Logging
        if epoch % tr_cfg.log_every == 0 or epoch == 1:
            if device.type == "cuda":
                torch.cuda.synchronize()

            now = time.time()
            dt_train = max(now - last_log_time, 1e-12)
            sps = float((steps_since_log * tr_cfg.n_interior) / dt_train)
            last_log_time = time.time()
            steps_since_log = 0

            if device.type == "cuda":
                torch.cuda.reset_peak_memory_stats()
            mem_gb = compute_gpu_mem_gb()

            times_eval = torch.tensor([0.0, 0.25, 0.5, 0.75, 1.0], device=device, dtype=dtype)
            metrics = evaluate_metrics(
                model=model,
                ctrl=ctrl,
                mat=mat,
                physics=physics,
                nd_cfg=nd_cfg,
                targets=targets,
                n_eval_scenarios=2,
                n_space=512,
                times=times_eval,
                device=device,
                dtype=dtype,
                sps=sps,
                mem_gb=mem_gb
            )

            row = {
                "epoch": float(epoch),
                "loss_total": float(total.item()),
                "Lpde": float(Lpde.item()),
                "Lbc": float(Lbc.item()),
                "Lic": float(Lic.item()),
                "Lphase": float(Lphase.item()),
                "Ltrack": float(Ltrack.item()),
                "Lband": float(Lband.item()),
                "Luni": float(Luni.item()),
                "Lctrl": float(Lctrl.item()),
                "curr_pde": float(curr_pde),
                "reg": float(reg),
                "lr": float(opt.param_groups[0]["lr"]),
                **{k: float(v) for k, v in metrics.items()},
            }
            log.log_row(row)

            print(
                f"[{epoch}/{tr_cfg.epochs}] "
                f"loss={row['loss_total']:.3e} pde={row['Lpde']:.3e} bc={row['Lbc']:.2e} ic={row['Lic']:.2e} "
                f"trk={row['Ltrack']:.2e} band={row['Lband']:.2e} uni={row['Luni']:.2e} "
                f"E1rms={row['E1_rms']:.2e} rmseμ={row['rmse_mean']:.2e} fracμ={row['frac_in_band_mean']:.2f} "
                f"CV={row['CV_T']:.2e} phī={row['phi_mean']:.3f} lat={row['latent_ratio']:.3f} η_lat={row['eta_latent']:.2f} "
                f"k_eff≈{row['k_eff_phys_est']:.1f}W/mK sps={row['sps']:.0f} η_sim={row['eta_sim_core']:.3f} η_ctrl={row['eta_control_core']:.3f}"
            )

            if scheduler is not None:
                scheduler.step(row["loss_total"])

            meets = (
                (epoch >= tr_cfg.early_stop_min_epoch)
                and (row["eta_sim_core"] >= targets.eta_total_sim_target)
                and (row["eta_control_core"] >= targets.eta_total_control_target)
                and (row["E1_rms"] <= 2.0 * targets.E1rms_target)
            )
            success_streak = success_streak + 1 if (tr_cfg.early_stop and meets) else 0
            if tr_cfg.early_stop and success_streak >= tr_cfg.early_stop_patience_logs:
                print("Early stopping: sim+control targets satisfied.")
                break

    # Optional L-BFGS refinement (helps drive PDE residual down)
    if tr_cfg.use_lbfgs_refine and tr_cfg.lbfgs_steps > 0:
        print("Starting L-BFGS refinement...")
        model.train()
        if ctrl is not None:
            ctrl.train()

        lbfgs = optim.LBFGS(
            list(model.parameters()) + (list(ctrl.parameters()) if ctrl is not None else []),
            lr=1.0,
            max_iter=tr_cfg.lbfgs_steps,
            history_size=50,
            line_search_fn="strong_wolfe"
        )

        Xi, m_i = sample_scenario_batch_interior(mat, tr_cfg.n_scenarios, tr_cfg.n_interior, dim, device, dtype)
        Xb, nb, m_b = sample_scenario_batch_boundary(mat, tr_cfg.n_scenarios, tr_cfg.n_boundary, dim, device, dtype)
        X0, m_0 = sample_scenario_batch_initial(mat, tr_cfg.n_scenarios, tr_cfg.n_initial, dim, device, dtype)
        Xi.requires_grad_(True)
        Xb.requires_grad_(True)
        X0.requires_grad_(True)

        track_times = torch.tensor(list(tr_cfg.track_times), device=device, dtype=dtype)
        Xt, mt = sample_scenario_time_slices(mat, tr_cfg.n_scenarios, tr_cfg.n_track_space, track_times, dim, device, dtype)

        def closure():
            lbfgs.zero_grad(set_to_none=True)

            out_i = model(Xi, m_i)
            out_b = model(Xb, m_b)
            out_0 = model(X0, m_0)
            out_t = model(Xt, mt)

            out_i = {k: v.float() for k, v in out_i.items()}
            out_b = {k: v.float() for k, v in out_b.items()}
            out_0 = {k: v.float() for k, v in out_0.items()}
            out_t = {k: v.float() for k, v in out_t.items()}

            q_ctrl = None
            if physics.use_control and ctrl is not None and physics.control_boundary:
                q_ctrl = ctrl.boundary(Xb, nb, m_b, physics.control_budget_q).float()

            props_i = mat.eval(out_i["T"], out_i.get("phi", None), m_i, nd_cfg)
            props_b = mat.eval(out_b["T"], out_b.get("phi", None), m_b, nd_cfg)

            rE = residual_energy(out_i, props_i, Xi, dim, physics)
            Lpde = torch.mean(rE**2)
            Lphase = loss_phase_consistency(out_i, props_i, Xi, dim, physics)
            rbc = residual_bc(out_b, props_b, Xb, nb, dim, physics, q_ctrl=q_ctrl)
            Lbc = torch.mean(rbc**2)
            ric = residual_ic(out_0, X0, physics)
            Lic = torch.mean(ric**2)

            # time-sliced tracking
            S = tr_cfg.n_scenarios
            Tn = track_times.numel()
            N = tr_cfg.n_track_space
            Tfield = out_t["T"].view(S, Tn, N, 1)
            T_mean = Tfield.mean(dim=2).squeeze(-1)
            tcol = track_times.view(1, Tn).repeat(S, 1)
            sp = setpoint_t(tcol, targets, physics)
            tol = float(targets.band_frac * max(abs(targets.T_set), 1e-6))
            Ltrack = torch.mean((T_mean - sp) ** 2)
            Lband = torch.mean(torch.relu(torch.abs(T_mean - sp) - tol) ** 2)
            Luni = torch.mean(Tfield.var(dim=2))

            Lent = entropy_production(out_i, props_i, Xi, dim)
            Lbnd = bounds_penalty(out_i)
            Lpri = priors_penalty(props_i)

            Lctrl = torch.tensor(0.0, device=device)
            if q_ctrl is not None:
                Lctrl = torch.mean(q_ctrl**2)

            total = (
                tr_cfg.w_pde * Lpde
                + tr_cfg.w_phase * Lphase
                + tr_cfg.w_bc * Lbc
                + tr_cfg.w_ic * Lic
                + tr_cfg.w_entropy * Lent
                + tr_cfg.w_bounds * Lbnd
                + tr_cfg.w_priors * Lpri
                + tr_cfg.w_track * Ltrack
                + tr_cfg.w_band * Lband
                + tr_cfg.w_uniformity * Luni
                + tr_cfg.w_ctrl * Lctrl
            )
            total.backward()
            return total

        lbfgs.step(closure)

    log.save()
    return model, ctrl, mat, log


