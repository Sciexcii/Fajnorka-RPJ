# ============================================================
# Logger
# ============================================================
class Logger:
    def __init__(self, out_dir: str, run_name: str):
        self.out_dir = out_dir
        self.run_name = run_name
        os.makedirs(out_dir, exist_ok=True)
        self.meta: Dict[str, Any] = {}
        self.rows: List[Dict[str, float]] = []
        self.t0 = time.time()

    def log_meta(self, k: str, v: Any) -> None:
        self.meta[k] = v

    def log_row(self, row: Dict[str, float]) -> None:
        self.rows.append(row)

    def save(self) -> None:
        self.meta["runtime_sec"] = float(time.time() - self.t0)
        with open(os.path.join(self.out_dir, f"{self.run_name}_meta.json"), "w") as f:
            json.dump(self.meta, f, indent=2)

        if self.rows:
            keys = sorted(self.rows[0].keys())
            with open(os.path.join(self.out_dir, f"{self.run_name}_log.csv"), "w") as f:
                f.write(",".join(keys) + "\n")
                for r in self.rows:
                    f.write(",".join(str(float(r.get(k, 0.0))) for k in keys) + "\n")


