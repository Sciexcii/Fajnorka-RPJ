def make_profile(profile: str) -> Tuple[PhysicsConfig, NondimConfig, MaterialConfig, NetConfig, TrainConfig, Targets]:
    profile = profile.lower().strip()

    nd_cfg = NondimConfig()
    net_cfg = NetConfig()
    tr_cfg = TrainConfig(run_name=f"phasetropy_v9_{profile}")
    targets = Targets()

    if profile == "metals_sim":
        mat_cfg = MaterialConfig(group_name="metals", use_microstructure=True)
        physics = PhysicsConfig(
            dim=2,
            bc_type="robin",
            use_sources=True,
            phase_mode="none",
            use_control=True,
            control_boundary=True,
            control_budget_q=0.08,
            track_setpoint_mode="ambient",
            track_mean_temperature=True,
        )

    elif profile == "pcm_latent":
        mat_cfg = MaterialConfig(group_name="pcm", use_microstructure=True)
        physics = PhysicsConfig(
            dim=2,
            bc_type="robin",
            use_sources=True,
            phase_mode="pcm_equilibrium",
            phase_beta=18.0,
            use_control=True,
            control_boundary=True,
            control_budget_q=0.08,
            track_setpoint_mode="ambient",
            track_mean_temperature=True,
        )
        targets.T_set = 0.25
        targets.latent_ratio_target = 0.20
        targets.latent_ratio_sigma = 0.15

    elif profile == "control_demo":
        mat_cfg = MaterialConfig(group_name="metals", use_microstructure=True)
        physics = PhysicsConfig(
            dim=2,
            bc_type="robin",
            use_sources=True,
            phase_mode="none",
            use_control=True,
            control_boundary=True,
            control_budget_q=0.14,
            track_setpoint_mode="ambient",
            track_mean_temperature=True,
        )
        tr_cfg.stage1_frac = 0.35
        tr_cfg.w_track = 28.0
        tr_cfg.w_band = 40.0
        tr_cfg.w_uniformity = 2.0
        tr_cfg.w_ctrl = 0.20
        targets.rmse_set_target = 0.02
        targets.frac_in_band_target = 0.85

    else:
        raise ValueError(f"Unknown profile: {profile}")

    return physics, nd_cfg, mat_cfg, net_cfg, tr_cfg, targets


