# AMP helpers
# ============================================================
class NullScaler:
    def scale(self, loss: torch.Tensor) -> torch.Tensor:
        return loss

    def unscale_(self, optimizer: optim.Optimizer) -> None:
        return None

    def step(self, optimizer: optim.Optimizer) -> None:
        optimizer.step()

    def update(self) -> None:
        return None


def make_scaler(device: torch.device, enabled: bool) -> Any:
    if device.type == "cuda" and enabled:
        return torch.amp.GradScaler("cuda", enabled=True)
    return NullScaler()


def autocast_ctx(device: torch.device, enabled: bool, dtype: torch.dtype):
    from contextlib import nullcontext
    if device.type == "cuda" and enabled:
        return torch.amp.autocast("cuda", enabled=True, dtype=dtype)
    return nullcontext()


def compute_gpu_mem_gb() -> float:
    if not torch.cuda.is_available():
        return 0.0
    return float(torch.cuda.max_memory_allocated() / (1024 ** 3))


