# Design search (microstructure-driven)
# ============================================================
def k_eff_score_smooth(k_eff_wmk: float) -> float:
    return float(math.tanh(k_eff_wmk / 600.0))


def design_random_search(
    model: MultiFieldPINN,
    mat: MaterialModel,
    physics: PhysicsConfig,
    nd_cfg: NondimConfig,
    targets: Targets,
    n_candidates: int = 300,
    n_eval_space: int = 512,
    times: Optional[List[float]] = None,
    device: Optional[torch.device] = None,
    dtype: torch.dtype = torch.float32,
) -> List[Dict[str, Any]]:
    if not mat.cfg.use_microstructure:
        raise ValueError("design_random_search requires microstructure enabled.")
    if device is None:
        device = get_device()

    dim = physics.dim
    model.eval()

    times_t = torch.tensor(times if times is not None else [0.2, 0.5, 0.8], device=device, dtype=dtype)

    # Fix base; vary micro only
    m_base = mat.sample_material_vector(1)
    base, _ = mat.split_vec(m_base)

    results: List[Dict[str, Any]] = []

    def sample_micro_candidate() -> torch.Tensor:
        f = torch.empty(1, 1, device=device, dtype=dtype).uniform_(0.0, 0.30)
        por = torch.empty(1, 1, device=device, dtype=dtype).uniform_(0.0, 0.15)
        aspect = torch.empty(1, 1, device=device, dtype=dtype).uniform_(5.0, 800.0)
        orient = torch.empty(1, 1, device=device, dtype=dtype).uniform_(0.0, 1.0)
        disp = torch.empty(1, 1, device=device, dtype=dtype).uniform_(0.3, 1.0)
        Rint = torch.empty(1, 1, device=device, dtype=dtype).uniform_(1e-10, 8e-8)
        return torch.cat([f, por, aspect, orient, disp, Rint], dim=1)

    for _ in range(n_candidates):
        micro = sample_micro_candidate()
        m_single = torch.cat([base, micro], dim=1)

        with torch.enable_grad():
            X = sample_time_slices(n_eval_space, times_t, dim, device, dtype)
            X.requires_grad_(True)
            m = m_single.repeat(X.shape[0], 1)

            out = model(X, m)
            out = {k: v.float() for k, v in out.items()}
            props = mat.eval(out["T"], out.get("phi", None), m, nd_cfg)

            rE = residual_energy(out, props, X, dim, physics)
            E1_rms = float(torch.sqrt(torch.mean(rE**2)).item())
            eta_phys = eta_rational(E1_rms, targets.E1rms_target, p=2.0)

            k_eff_star = float(torch.mean(props["K_star"]).item())
            k_eff_phys = float(k_eff_star * nd_cfg.k_ref)
            s_k = k_eff_score_smooth(k_eff_phys)

            gT = grad_scalar(out["T"], X, dim)
            grad_rms = float(torch.sqrt(torch.mean(torch.sum(gT**2, dim=1))).item())
            eta_grad = eta_rational(grad_rms, targets.grad_rms_target, p=2.0)

            latent_ratio = 0.0
            eta_lat = 1.0
            phi_mean = 0.0
            if physics.phase_mode.lower() == "pcm_equilibrium" and ("phi" in out):
                phi = out["phi"]
                phi_mean = float(phi.mean().item())
                dphidt = dt_scalar(phi, X, dim)
                latent_term = (1.0 / (props["Ste"] + 1e-12)) * dphidt
                latent_power = float(torch.mean(torch.abs(latent_term)).item())
                src = source_Sp(X, dim) if physics.use_sources else torch.zeros_like(latent_term)
                src_power = float(torch.mean(torch.abs(src)).item())
                latent_ratio = float(latent_power / (latent_power + src_power + 1e-12))
                eta_lat = eta_gaussian(latent_ratio, targets.latent_ratio_target, targets.latent_ratio_sigma)

        w_lat = 0.20 if physics.phase_mode.lower() == "pcm_equilibrium" else 0.00
        score = float(0.50 * s_k + 0.30 * eta_phys + 0.20 * eta_grad + w_lat * eta_lat)

        results.append({
            "score": score,
            "k_eff_phys_est": k_eff_phys,
            "E1_rms": E1_rms,
            "grad_rms": grad_rms,
            "latent_ratio": latent_ratio,
            "eta_latent": eta_lat,
            "phi_mean": phi_mean,
            "micro_vec": micro[0].detach().cpu().numpy().tolist(),
        })

    results.sort(key=lambda r: float(r["score"]), reverse=True)
    return results[:10]


