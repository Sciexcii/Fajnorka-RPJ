def configure_torch_for_speed(seed: int = 1234, deterministic: bool = False) -> None:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

    if torch.cuda.is_available():
        torch.backends.cuda.matmul.allow_tf32 = True
        torch.backends.cudnn.allow_tf32 = True
        torch.backends.cudnn.benchmark = not deterministic

    try:
        torch.set_float32_matmul_precision("high")
    except Exception:
        pass


def get_device() -> torch.device:
    return torch.device("cuda" if torch.cuda.is_available() else "cpu")


def logit(p: float) -> float:
    p = min(max(p, 1e-6), 1.0 - 1e-6)
    return float(math.log(p / (1.0 - p)))


# ============================================================
# torch.compile safety (Windows cl.exe)
# ============================================================
def _has_msvc_cl() -> bool:
    return shutil.which("cl") is not None


def can_use_torch_compile() -> Tuple[bool, str]:
    if not hasattr(torch, "compile"):
        return False, "torch.compile not available"
    if os.name == "nt" and not _has_msvc_cl():
        return False, "Windows detected but MSVC cl.exe not found (torch.compile/inductor would fail)"
    return True, "ok"


def maybe_compile(model: nn.Module, enabled: bool) -> nn.Module:
    if not enabled:
        return model
    ok, reason = can_use_torch_compile()
    if not ok:
        print(f"[compile] Disabled: {reason}")
        return model
    try:
        return torch.compile(model)
    except Exception as e:
        print(f"[compile] Failed -> eager fallback. {type(e).__name__}: {e}")
        return model


