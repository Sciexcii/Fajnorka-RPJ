# Optional viz
# ============================================================
@torch.no_grad()
def viz_2d_T(model: MultiFieldPINN, mat: MaterialModel, physics: PhysicsConfig, nd_cfg: NondimConfig, device: torch.device, dtype: torch.dtype, t: float = 0.5, N: int = 120):
    if not HAS_MPL or physics.dim != 2:
        return
    x = torch.linspace(0, 1, N, device=device, dtype=dtype)
    y = torch.linspace(0, 1, N, device=device, dtype=dtype)
    Xg, Yg = torch.meshgrid(x, y, indexing="ij")
    tt = torch.full_like(Xg, float(t))
    X = torch.cat([Xg.reshape(-1, 1), Yg.reshape(-1, 1), tt.reshape(-1, 1)], dim=1)
    mvec = mat.sample_material_vector(X.shape[0])
    out = model(X, mvec)
    T = out["T"].reshape(N, N).detach().cpu().numpy()
    plt.figure()
    plt.imshow(T, origin="lower", extent=[0, 1, 0, 1], aspect="equal")
    plt.colorbar(label="T*")
    plt.title(f"2D T*(x,y,t={t})")
    plt.show()


