# ============================================================
# Nondimensionalization
# ============================================================
class Nondim:
    def __init__(self, cfg: NondimConfig):
        self.cfg = cfg
        self.alpha_ref = cfg.k_ref / (cfg.rho_ref * cfg.C_ref)
        self.t0 = (cfg.L0 ** 2) / self.alpha_ref

    def T_phys(self, T_star: torch.Tensor) -> torch.Tensor:
        return self.cfg.Tref + self.cfg.dT * T_star


# ============================================================
# Material priors + effective medium
# ============================================================
class MaterialPriors:
    def __init__(self, group: str):
        self.group = group.lower()

    def sample_base(self, n: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
        g = self.group
        if g == "pcm":
            k0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.1, 5.0)
            kT = torch.empty(n, 1, device=device, dtype=dtype).uniform_(-0.3, 0.3)
            C0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1200, 3000)
            rho0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(700, 2000)
            L = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1e5, 4e5)
            Tm = torch.empty(n, 1, device=device, dtype=dtype).uniform_(290, 380)
            G = torch.zeros(n, 1, device=device, dtype=dtype)
            tau_q = torch.zeros(n, 1, device=device, dtype=dtype)
            ell_q = torch.zeros(n, 1, device=device, dtype=dtype)
            h = torch.empty(n, 1, device=device, dtype=dtype).uniform_(5, 500)
            eps = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.2, 0.95)
            hK = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1e3, 1e7)
        elif g == "metals":
            k0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(80, 400)
            kT = torch.empty(n, 1, device=device, dtype=dtype).uniform_(-0.2, 0.2)
            C0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(300, 900)
            rho0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(2500, 9000)
            # metals: default no latent
            L = torch.zeros(n, 1, device=device, dtype=dtype)
            Tm = torch.empty(n, 1, device=device, dtype=dtype).uniform_(800, 1400)
            G = torch.zeros(n, 1, device=device, dtype=dtype)
            tau_q = torch.zeros(n, 1, device=device, dtype=dtype)
            ell_q = torch.zeros(n, 1, device=device, dtype=dtype)
            h = torch.empty(n, 1, device=device, dtype=dtype).uniform_(10, 2000)
            eps = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.05, 0.95)
            hK = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1e4, 1e8)
        else:
            k0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.1, 200)
            kT = torch.empty(n, 1, device=device, dtype=dtype).uniform_(-0.2, 0.2)
            C0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(300, 2500)
            rho0 = torch.empty(n, 1, device=device, dtype=dtype).uniform_(800, 9000)
            L = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.0, 4e5)
            Tm = torch.empty(n, 1, device=device, dtype=dtype).uniform_(300, 1400)
            G = torch.zeros(n, 1, device=device, dtype=dtype)
            tau_q = torch.zeros(n, 1, device=device, dtype=dtype)
            ell_q = torch.zeros(n, 1, device=device, dtype=dtype)
            h = torch.empty(n, 1, device=device, dtype=dtype).uniform_(2, 1000)
            eps = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.05, 0.95)
            hK = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1e3, 1e7)

        return torch.cat([k0, kT, C0, rho0, L, Tm, G, tau_q, ell_q, h, eps, hK], dim=1)

    def sample_micro(self, n: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
        # [filler_fraction, porosity, aspect, orient, dispersion, Rint]
        f = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.0, 0.35)
        por = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.0, 0.4)
        aspect = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1.0, 200.0)
        orient = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.0, 1.0)
        disp = torch.empty(n, 1, device=device, dtype=dtype).uniform_(0.2, 1.0)
        Rint = torch.empty(n, 1, device=device, dtype=dtype).uniform_(1e-9, 1e-7)
        return torch.cat([f, por, aspect, orient, disp, Rint], dim=1)


class EffectiveMedium:
    def k_eff(self, k_matrix: torch.Tensor, k_filler: torch.Tensor, micro: torch.Tensor) -> torch.Tensor:
        f = micro[:, 0:1].clamp(0.0, 0.8)
        por = micro[:, 1:2].clamp(0.0, 0.9)
        aspect = micro[:, 2:3].clamp(1.0, 1e4)
        orient = micro[:, 3:4].clamp(0.0, 1.0)
        disp = micro[:, 4:5].clamp(0.0, 1.0)
        Rint = micro[:, 5:6].clamp(1e-12, 1e-4)

        shape_boost = 1.0 + 0.3 * torch.tanh((aspect - 1.0) / 50.0) * orient
        disp_boost = 0.7 + 0.3 * disp
        kf_eff = k_filler / (1.0 + 1e7 * Rint)

        num = k_matrix * (kf_eff + 2 * k_matrix + 2 * f * (kf_eff - k_matrix))
        den = (kf_eff + 2 * k_matrix - f * (kf_eff - k_matrix)).clamp(min=1e-12)
        k_mg = num / den

        f0 = 0.15 / shape_boost.clamp(min=0.5, max=3.0)
        s = torch.sigmoid(30.0 * (f - f0))
        k_perc = k_matrix * (1.0 + 20.0 * (f**1.5) * shape_boost * disp_boost)

        k_mix = (1 - s) * k_mg + s * k_perc
        return k_mix * (1.0 - por).clamp(min=0.05)


class MaterialModel:
    def __init__(self, cfg: MaterialConfig, nd: Nondim, device: torch.device, dtype: torch.dtype):
        self.cfg = cfg
        self.nd = nd
        self.device = device
        self.dtype = dtype
        self.priors = MaterialPriors(cfg.group_name)
        self.em = EffectiveMedium()
        self.k_filler_typ = 2000.0 if cfg.group_name.lower() in ("pcm", "polymers") else 500.0

    def sample_material_vector(self, n: int) -> torch.Tensor:
        base = self.priors.sample_base(n, self.device, self.dtype)
        if self.cfg.use_microstructure:
            micro = self.priors.sample_micro(n, self.device, self.dtype)
            return torch.cat([base, micro], dim=1)
        return base

    def split_vec(self, mvec: torch.Tensor) -> Tuple[torch.Tensor, Optional[torch.Tensor]]:
        base = mvec[:, : self.cfg.base_vec_dim]
        micro = None
        if self.cfg.use_microstructure:
            micro = mvec[:, self.cfg.base_vec_dim:self.cfg.base_vec_dim + self.cfg.micro_vec_dim]
        return base, micro

    def _k_phys(self, T_phys: torch.Tensor, base: torch.Tensor, micro: Optional[torch.Tensor], phi: Optional[torch.Tensor], nd_cfg: NondimConfig) -> torch.Tensor:
        k0 = base[:, 0:1]
        kT = base[:, 1:2]
        dT = (T_phys - nd_cfg.Tref) / max(nd_cfg.dT, 1e-12)
        k_matrix = (k0 * (1.0 + kT * dT)).clamp(min=1e-6)

        # phi reduces k (interpretable melt fraction or damage)
        if phi is not None:
            k_matrix = k_matrix * (1.0 - 0.35 * phi.clamp(0.0, 1.0))

        if micro is not None:
            k_filler = torch.full_like(k_matrix, float(self.k_filler_typ))
            return self.em.k_eff(k_matrix, k_filler, micro)
        return k_matrix

    def _C_phys(self, T_phys: torch.Tensor, base: torch.Tensor, phi: Optional[torch.Tensor], nd_cfg: NondimConfig) -> torch.Tensor:
        C0 = base[:, 2:3]
        dT = (T_phys - nd_cfg.Tref) / max(nd_cfg.dT, 1e-12)
        C = C0 * (1.0 + 0.05 * torch.tanh(dT))
        if phi is not None:
            C = C * (1.0 + 0.10 * phi.clamp(0.0, 1.0))
        return C.clamp(min=1e-6)

    def eval(self, T_star: torch.Tensor, phi: Optional[torch.Tensor], mvec: torch.Tensor, nd_cfg: NondimConfig) -> Dict[str, torch.Tensor]:
        base, micro = self.split_vec(mvec)
        T_phys = self.nd.T_phys(T_star)

        L_phys = base[:, 4:5].clamp(min=0.0)
        Tm_phys = base[:, 5:6].clamp(min=1.0)

        tau_q_phys = base[:, 7:8].clamp(min=0.0)
        ell_q_phys = base[:, 8:9].clamp(min=0.0)

        h_phys = base[:, 9:10].clamp(min=0.0)
        eps = base[:, 10:11].clamp(0.0, 1.0)
        hK_phys = base[:, 11:12].clamp(min=1.0)

        k_phys = self._k_phys(T_phys, base, micro, phi, nd_cfg)
        C_phys = self._C_phys(T_phys, base, phi, nd_cfg)

        C_hat = C_phys / nd_cfg.C_ref
        K_star = k_phys / nd_cfg.k_ref

        Ste = (nd_cfg.C_ref * nd_cfg.dT) / (L_phys + 1e-12)
        Ste = Ste.clamp(min=1e-6, max=1e12)

        Theta_q = tau_q_phys / (self.nd.t0 + 1e-12)
        Lambda_q = ell_q_phys / (nd_cfg.L0 + 1e-12)

        Bi_c = h_phys * nd_cfg.L0 / (nd_cfg.k_ref + 1e-12)
        Bi_K = hK_phys * nd_cfg.L0 / (nd_cfg.k_ref + 1e-12)

        return {
            "C_hat": C_hat,
            "K_star": K_star,
            "Ste": Ste,
            "Theta_q": Theta_q,
            "Lambda_q": Lambda_q,
            "Bi_c": Bi_c,
            "Bi_K": Bi_K,
            "eps": eps,
            "Tm_star": (Tm_phys - nd_cfg.Tref) / nd_cfg.dT,
        }


# ============================================================
# Networks
# ============================================================
def sigmoid01(x: torch.Tensor) -> torch.Tensor:
    return torch.sigmoid(x)


class FourierFeatures(nn.Module):
    def __init__(self, in_dim: int, out_dim: int, scale: float, device: torch.device, dtype: torch.dtype):
        super().__init__()
        B = torch.randn(in_dim, out_dim, device=device, dtype=dtype) * scale
        self.register_buffer("B", B)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x_proj = 2 * math.pi * (x @ self.B)
        return torch.cat([torch.sin(x_proj), torch.cos(x_proj)], dim=-1)


class MLP(nn.Module):
    def __init__(self, in_dim: int, hidden: int, depth: int, out_dim: int, dropout: float = 0.0):
        super().__init__()
        layers: List[nn.Module] = []
        d = in_dim
        for _ in range(depth):
            layers += [nn.Linear(d, hidden), nn.Tanh()]
            if dropout > 0:
                layers.append(nn.Dropout(p=dropout))
            d = hidden
        layers.append(nn.Linear(d, out_dim))
        self.net = nn.Sequential(*layers)
        self._init()

    def _init(self) -> None:
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.xavier_uniform_(m.weight, gain=1.0)
                nn.init.constant_(m.bias, 0.0)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.net(x)


class MultiFieldPINN(nn.Module):
    """
    Outputs:
      - T in [0,1]
      - phi in [0,1] if phase_mode != "none"
    """
    def __init__(self, dim: int, mat_dim: int, net_cfg: NetConfig, physics: PhysicsConfig, device: torch.device, dtype: torch.dtype):
        super().__init__()
        self.dim = dim
        self.physics = physics

        in_dim = (dim + 1) + mat_dim
        self.ff: Optional[FourierFeatures] = None
        if net_cfg.use_fourier_features:
            self.ff = FourierFeatures(in_dim, net_cfg.fourier_dim, net_cfg.fourier_scale, device=device, dtype=dtype)
            trunk_in = 2 * net_cfg.fourier_dim
        else:
            trunk_in = in_dim

        self.trunk = MLP(trunk_in, net_cfg.hidden, net_cfg.depth, net_cfg.hidden, dropout=net_cfg.dropout)
        self.head_T = nn.Linear(net_cfg.hidden, 1)
        self.head_phi = None if physics.phase_mode.lower() == "none" else nn.Linear(net_cfg.hidden, 1)

        nn.init.xavier_uniform_(self.head_T.weight, gain=1.0)
        nn.init.constant_(self.head_T.bias, logit(0.2))

        if self.head_phi is not None:
            nn.init.xavier_uniform_(self.head_phi.weight, gain=1.0)
            nn.init.constant_(self.head_phi.bias, logit(1e-4))

    def forward(self, X: torch.Tensor, mvec: torch.Tensor) -> Dict[str, torch.Tensor]:
        z = torch.cat([X, mvec], dim=1)
        if self.ff is not None:
            z = self.ff(z)
        h = self.trunk(z)
        out: Dict[str, torch.Tensor] = {"T": sigmoid01(self.head_T(h))}
        if self.head_phi is not None:
            out["phi"] = sigmoid01(self.head_phi(h))
        return out


class ControlNet(nn.Module):
    def __init__(self, dim: int, mat_dim: int, hidden: int, depth: int):
        super().__init__()
        self.boundary_net = MLP((dim + 1) + dim + mat_dim, hidden, depth, 1, dropout=0.0)

    def boundary(self, Xb: torch.Tensor, nb: torch.Tensor, mvec: torch.Tensor, budget: float) -> torch.Tensor:
        inp = torch.cat([Xb, nb, mvec], dim=1)
        return budget * torch.tanh(self.boundary_net(inp))


# ============================================================
# Autograd helpers
# ============================================================
def _grad(outputs: torch.Tensor, inputs: torch.Tensor) -> torch.Tensor:
    return torch.autograd.grad(
        outputs=outputs,
        inputs=inputs,
        grad_outputs=torch.ones_like(outputs),
        create_graph=True,
        retain_graph=True,
        only_inputs=True,
    )[0]


def grad_scalar(y: torch.Tensor, X: torch.Tensor, dim: int) -> torch.Tensor:
    return _grad(y, X)[:, :dim]


def dt_scalar(y: torch.Tensor, X: torch.Tensor, dim: int) -> torch.Tensor:
    return _grad(y, X)[:, dim:dim+1]


def div_vector(v: torch.Tensor, X: torch.Tensor, dim: int) -> torch.Tensor:
    div = 0.0
    for i in range(dim):
        div = div + _grad(v[:, i:i+1], X)[:, i:i+1]
    return div


